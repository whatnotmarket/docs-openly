  "logo": {
    "light": "/images/logosvgblack.svg",
    "dark": "/images/logosvgwhite.svg",
    "href": "https://docs.openlymarket.xyz/"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://openlymarket.xyz"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/openlymarket",
      "github": "https://github.com/openlydev"
    }
  },
  "fonts": {
    "family": "Geist"
  },
  "background": {
    "decoration": "windows"
  },
  "appearance": {
    "default": "dark"
  }
